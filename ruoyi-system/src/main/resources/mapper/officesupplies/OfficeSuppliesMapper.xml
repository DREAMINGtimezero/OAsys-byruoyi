    <sql id="selectOfficeSuppliesVo">
        select supplies_name, unit_price, quantity, total_cost, description, status, id, create_by, update_by, create_time, update_time, delete_flag from t_office_supplies
    </sql>

    <sql id="selectOfficeSuppliesSubVo">
        select office_supplies_id, initiate_note, initiate_time, handle_by, handle_note, handle_time, file_names, status, id, create_by, update_by, create_time, update_time, delete_flag from t_office_supplies_sub
    </sql>

    <select id="selectOfficeSuppliesList" parameterType="OfficeSupplies" resultMap="OfficeSuppliesResult">
        <include refid="selectOfficeSuppliesVo"/>

        <where>
            <if test="createBy != null  and createBy != ''">
                EXISTS (
                SELECT 1 FROM t_office_supplies_sub tos  WHERE  t_office_supplies.id = tos.office_supplies_id
                and tos.delete_flag = 0 and (tos.create_by = #{createBy} OR tos.handle_by = #{createBy})
                )
            </if>
            and t_office_supplies.delete_flag = 0
            <if test="suppliesName != null  and suppliesName != ''"> and supplies_name like concat('%', #{suppliesName}, '%')</if>
            <if test="unitPrice != null and unitPrice != ''"> and unit_price = #{unitPrice}</if>
            <if test="quantity != null and quantity != ''"> and quantity = #{quantity}</if>
            <if test="totalCost != null and totalCost != ''"> and total_cost = #{totalCost}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="params.startTime != null and params.startTime != ''"> and create_time >= #{params.startTime}</if>
            <if test="params.endTime != null and params.endTime != ''"> and create_time &lt;= #{params.endTime}</if>
        </where>
    </select>

    <select id="selectOfficeSuppliesById" parameterType="Long" resultMap="OfficeSuppliesResult">
        <include refid="selectOfficeSuppliesVo"/>
        where id = #{id}
    </select>

    <select id="selectOfficeSuppliesByIds" parameterType="java.util.List" resultMap="OfficeSuppliesResult">
        <include refid="selectOfficeSuppliesVo"/>
        where id in
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <insert id="insertOfficeSupplies" parameterType="OfficeSupplies" useGeneratedKeys="true" keyProperty="id">
        insert into t_office_supplies
        <trim prefix="(" suffix=")" suffixOverrides=",">
