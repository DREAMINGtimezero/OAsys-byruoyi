    <update id="updateOfficeSupplies" parameterType="OfficeSupplies">
        update t_office_supplies
        <trim prefix="SET" suffixOverrides=",">
            <if test="suppliesName != null and suppliesName != ''">supplies_name = #{suppliesName},</if>
