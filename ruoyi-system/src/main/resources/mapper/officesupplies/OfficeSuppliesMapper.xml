            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="deleteFlag != null">delete_flag = #{deleteFlag},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteOfficeSuppliesById" parameterType="Long">
        update t_office_supplies set delete_flag = 1,update_time = sysdate()
        where id = #{id}
    </delete>

    <delete id="deleteOfficeSuppliesByIds" parameterType="String">
        update t_office_supplies set delete_flag = 1,update_time = sysdate()
