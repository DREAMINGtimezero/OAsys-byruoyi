<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.enterprise.mapper.EnterpriseSubMapper">
    <resultMap id="EnterpriseSubResult" type="EnterpriseSub">
        <result property="id" column="id"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleteFlag" column="delete_flag"/>
        <result property="enterpriseId" column="enterprise_id"/>
        <result property="wayOfVision" column="way_of_vision"/>
        <result property="progress" column="progress"/>
        <result property="communicationTime" column="communication_time"/>
        <result property="note" column="note"/>
    </resultMap>

    <sql id="selectEnterpriseSubVo">
        select id,
               create_by,
               update_by,
               create_time,
               update_time,
               delete_flag,
               enterprise_id,
               way_of_vision,
               progress,
               communication_time,
               note
        from t_enterprise_sub
    </sql>

    <select id="selectEnterpriseSubById" parameterType="Long" resultMap="EnterpriseSubResult">
        <include refid="selectEnterpriseSubVo"/>
        where id = #{id}
    </select>

    <select id="selectEnterpriseSubList" parameterType="EnterpriseSub" resultMap="EnterpriseSubResult">
        <include refid="selectEnterpriseSubVo"/>
        <where>
            delete_flag = 0
            <if test="enterpriseId != null">and enterprise_id = #{enterpriseId}</if>
            <if test="wayOfVision != null and wayOfVision != ''">and way_of_vision = #{wayOfVision}</if>
            <if test="progress != null and progress != ''">and progress like concat('%', #{progress}, '%')</if>
            <if test="communicationTime != null">and communication_time = #{communicationTime}</if>
        </where>
        order by communication_time desc
    </select>

    <select id="selectEnterpriseSubListByEnterpriseId" parameterType="Long" resultMap="EnterpriseSubResult">
        <include refid="selectEnterpriseSubVo"/>
        where enterprise_id = #{enterpriseId} and delete_flag = 0
        order by communication_time desc
    </select>

    <insert id="insertEnterpriseSub" parameterType="EnterpriseSub" useGeneratedKeys="true" keyProperty="id">
        insert into t_enterprise_sub
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="deleteFlag != null">delete_flag,</if>
            <if test="enterpriseId != null">enterprise_id,</if>
            <if test="wayOfVision != null">way_of_vision,</if>
            <if test="progress != null">progress,</if>
            <if test="communicationTime != null">communication_time,</if>
            <if test="note != null">note,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="deleteFlag != null">#{deleteFlag},</if>
            <if test="enterpriseId != null">#{enterpriseId},</if>
            <if test="wayOfVision != null">#{wayOfVision},</if>
            <if test="progress != null">#{progress},</if>
            <if test="communicationTime != null">#{communicationTime},</if>
            <if test="note != null">#{note},</if>
        </trim>
    </insert>

    <update id="updateEnterpriseSub" parameterType="EnterpriseSub">
        update t_enterprise_sub
        <set>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="deleteFlag != null">delete_flag = #{deleteFlag},</if>
            <if test="enterpriseId != null">enterprise_id = #{enterpriseId},</if>
            <if test="wayOfVision != null">way_of_vision = #{wayOfVision},</if>
            <if test="progress != null">progress = #{progress},</if>
            <if test="communicationTime != null">communication_time = #{communicationTime},</if>
            <if test="note != null">note = #{note},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteEnterpriseSubById" parameterType="Long">
        update t_enterprise_sub set delete_flag = 1, update_by=#{loginName}
        where id = #{id}
    </delete>

    <delete id="deleteEnterpriseSubByIds" parameterType="String">
        update t_enterprise_sub set delete_flag = 1, update_time = sysdate()
        where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>