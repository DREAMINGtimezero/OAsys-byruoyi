<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.selfevaluation.mapper.SelfEvaluationMapper">
    <update id="submitSelfEvaluation">
        update t_evaluation set status = 2,update_by = #{updateBy},update_time = #{updateTime} where id = #{id}
    </update>
    <delete id="deleteSelfEvaluationById">
        delete from t_evaluation where id = #{id}
    </delete>

    <select id="selectEvalutionList" resultType="com.ruoyi.selfevaluation.domain.SelfEvaluation">
    select id,file_names, create_by, update_by, create_time, update_time, delete_flag,status from t_evaluation
    <where>
        <if test="createBy != null  and createBy != ''and !isCeo">
            and create_by = #{createBy}
        </if>
        <if test="isCeo">
            and (status = 2 or create_by = #{createBy})
        </if>
        and delete_flag = 0
        <if test="startTime != null and startTime != ''"> and create_time >= #{startTime}</if>
        <if test="endTime != null and endTime != ''"> and create_time &lt;= #{endTime}</if>
        <if test="status != null and status !='' "> and status = #{status}</if>
    </where>
    </select>
    <insert id="insertEvalution">
       insert into t_evaluation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="fileNames != null">file_names,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="deleteFlag != null">delete_flag,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="fileNames != null">#{fileNames},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="deleteFlag != null">#{deleteFlag},</if>
        </trim>
    </insert>

</mapper>